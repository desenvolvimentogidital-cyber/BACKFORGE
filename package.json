{
  "name": "backforge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/queues/worker.ts",
    "build": "npm run prisma:generate && npm run clean && npm run build:server && npm run copy:generated && npm run build:client && npm run copy:entry",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "copy:generated": "node -e \"const { cpSync, existsSync } = require('node:fs'); if (existsSync('src/generated/prisma-client')) { cpSync('src/generated/prisma-client', 'dist/server/generated/prisma-client', { recursive: true }); }\"",
    "copy:entry": "node -e \"const { mkdirSync, writeFileSync } = require('node:fs'); mkdirSync('dist', { recursive: true }); writeFileSync('dist/server.js', \\\"import './server/server.js';\\\");\"",
    "start": "node dist/server.js",
    "start:worker": "node dist/server/queues/worker.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:dev": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "clean": "node -e \"const { rmSync } = require('node:fs'); for (const dir of ['dist/server', 'dist/client', 'dist/server.js']) { try { rmSync(dir, { recursive: true, force: true, maxRetries: 5, retryDelay: 200 }); } catch (error) { if (error && error.code !== 'ENOENT') { console.warn('[clean] could not fully remove ' + dir + ': ' + error.message); } } }\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:migrations": "vitest run tests/production.integration.test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/express": "^4.0.4",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.1",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "fastify": "^5.8.4",
    "graphql": "^16.13.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "mercurius": "^16.8.0",
    "prisma": "^6.19.2",
    "prom-client": "^15.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.13.2",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^9.39.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.2.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "ioredis": "$ioredis"
  }
}

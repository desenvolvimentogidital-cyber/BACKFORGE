DATABASE_URL=""
REDIS_URL=""

JWT_SECRET=""
NODE_ENV=production
PORT=3000
APP_URL=""
CORS_ORIGIN=""

ENABLE_GRAPHQL=false
ENABLE_DEV_AUTH_FALLBACK=false
LOG_LEVEL="info"
FEATURE_FLAGS='{"eventBusV1":true,"rolloutAutomation":true,"canaryDeployments":true,"auditEvents":true}'
VITE_FEATURE_FLAGS='{"newDashboard":true,"launchLandingPage":true,"docsCallout":true}'

METRICS_ENABLED=true
METRICS_PORT=9090
ENABLE_CLUSTER=false
CLUSTER_WORKERS=0

QUEUE_NAME="jobs"
QUEUE_CONCURRENCY=4
GLOBAL_RATE_LIMIT_MAX=100
GLOBAL_RATE_LIMIT_WINDOW_MINUTES=15

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_PRO=""

S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="backforge-storage"

# Production checklist:
# NODE_ENV=production
# DATABASE_URL must come from Railway Postgres or another managed PostgreSQL service.
# REDIS_URL should come from Railway Redis or another managed Redis service.
# JWT_SECRET must be unique, random, and at least 32 characters.
# APP_URL and CORS_ORIGIN must match the public Railway/custom domain.
